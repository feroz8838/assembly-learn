{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Assembly",
      "type": "gdb",
      "request": "launch",
      "target": ":1234",
      "cwd": "${workspaceFolder}",
      "remote": "true",
      "valuesFormatting": "parseText",
      "autorun": [
        "symbol-file videomem.elf ",
        "set output-radix 16"
      ]
    }
  ]
}