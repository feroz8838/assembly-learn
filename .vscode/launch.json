{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Bootloader",
      "type": "gdb",
      "request": "attach",
      "target":":1234",
      "remote": true,
      "cwd": "${workspaceFolder}",
      "valuesFormatting": "parseText",
      "autorun":[
        "symbol-file nasm/videomem.elf",
        "set output-radix 16"
      ]
    }
  ]
}